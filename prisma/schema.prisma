// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AssetProfile {
  id                   String   @id @default(cuid())
  instrumentType       String   // InstrumentType enum: STOCK | FUND
  isin                 String?  @unique
  ticker               String?
  name                 String?
  exchange             String?
  country              String?
  sector               String?
  industry             String?
  fundManager          String?
  fundCategory         String?  // FundCategory enum: EQUITY | BOND | COMBINATION
  equityPct            Decimal?
  bondPct              Decimal?
  sectorWeightings     String?  // JSON serialized as TEXT
  geographicWeightings String?  // JSON serialized as TEXT
  fieldSources         String   @default("{}")  // JSON serialized as TEXT
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  holdings             Holding[]
  candidates           EnrichmentCandidate[]
}


model Holding {
  id                   String   @id @default(cuid())
  instrumentIdentifier String
  instrumentType       String   // InstrumentType enum: STOCK | FUND
  accountName          String
  shares               Decimal?
  pricePerShare        Decimal?
  currentValue         Decimal?
  enrichmentStatus     String   @default("PENDING")  // EnrichmentStatus enum
  assetProfileId       String?
  lastUpdated          DateTime @default(now())
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  assetProfile         AssetProfile? @relation(fields: [assetProfileId], references: [id])

  @@unique([accountName, instrumentIdentifier])
}

model EnrichmentCache {
  id        String   @id @default(cuid())
  cacheKey  String   @unique
  data      String   // JSON serialized Partial<AssetProfileUpdateData>
  source    String   // which data source produced this entry
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model EnrichmentCandidate {
  id             String   @id @default(cuid())
  assetProfileId String
  name           String
  ticker         String?
  isin           String?
  exchange       String?
  instrumentType String   // STOCK | FUND
  sourceId       String
  rawData        String   // JSON serialized full source response
  score          Int      @default(0)
  createdAt      DateTime @default(now())

  assetProfile   AssetProfile @relation(fields: [assetProfileId], references: [id], onDelete: Cascade)
}
