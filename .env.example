# Database (PostgreSQL)
# Local dev: postgresql://postgres:postgres@localhost:5432/divest
# Production: set via environment/secrets manager (never commit real credentials)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/divest"

# Auth.js v5
AUTH_SECRET="your-secret-here"
# GitHub OAuth App credentials (GitHub → Settings → Developer settings → OAuth Apps)
AUTH_GITHUB_ID="your-github-oauth-app-client-id"
AUTH_GITHUB_SECRET="your-github-oauth-app-client-secret"
# Your numeric GitHub user ID: curl https://api.github.com/users/<username> | grep '"id"'
AUTH_GITHUB_OWNER_ID="your-numeric-github-user-id"
# Required when running behind a reverse proxy
AUTH_TRUST_HOST="true"

# AI Provider
AI_PROVIDER="stub"
AI_API_KEY=""

# App URL (used for fire-and-forget enrichment fetch)
NEXTAUTH_URL="http://localhost:3000"
