# Database (PostgreSQL)
# Local dev: postgresql://postgres:postgres@localhost:5432/divest
# Production: set via environment/secrets manager (never commit real credentials)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/divest"

# Auth.js v5
AUTH_SECRET="your-secret-here"
AUTH_USERNAME="admin"
# bcrypt hashes contain $ which Next.js interpolates — store as base64 and decode at runtime
# Generate with: node -e "const b=require('bcryptjs'); b.hash('yourpassword',10).then(h=>console.log(Buffer.from(h).toString('base64')))"
AUTH_PASSWORD_HASH_B64=your-base64-encoded-bcrypt-hash

# AI Provider
AI_PROVIDER="stub"
AI_API_KEY=""

# App URL (used for fire-and-forget enrichment fetch)
NEXTAUTH_URL="http://localhost:3000"
